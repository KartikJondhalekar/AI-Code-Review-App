{
  "name": "ai-code-review-app",
  "version": "0.1.0",
  "description": "AI-powered GitHub App for automated PR code review",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "verify:config": "ts-node src/index.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "zod": "^3.23.8",
    "@prisma/client": "^5.18.0",
    "ioredis": "^5.4.1",
    "openai": "^4.56.0",
    "@octokit/app": "^15.1.0",
    "@octokit/rest": "^21.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "@types/node": "^22.4.0",
    "@types/express": "^4.17.21",
    "prisma": "^5.18.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "@types/jest": "^29.5.12",
    "nock": "^13.5.4"
  }
}